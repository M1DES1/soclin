QWidget {
    font-family: "Segoe UI", "Noto Sans", sans-serif;
    font-size: 10pt;
}

QPushButton {
    background: #2563eb;
    color: white;
    border: 0;
    border-radius: 8px;
    padding: 8px 18px;
}

QPushButton:hover {
    background: #1d4ed8;
}

QPushButton:disabled {
    background: #64748b;
}

#sidebarApp {
    background-color: #0f172a;
    color: #cbd5e1;
}
