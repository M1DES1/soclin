#!/usr/bin/env bash
set -euo pipefail

useradd -m -s /bin/bash winux || true
usermod -aG sudo,video,audio,render,input,plugdev,netdev winux || true
chsh -s /bin/bash winux || true

systemctl enable NetworkManager
systemctl enable sddm

install -d -m 0755 /etc/skel/.config/qt6ct
install -d -m 0755 /etc/skel/.config/Kvantum
install -d -m 0755 /etc/skel/.config/systemd/user

chown -R winux:winux /home/winux || true
